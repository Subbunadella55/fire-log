# PyroChain Backend Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO VERSION CONTROL
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pyrochain

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_32chars_minimum
JWT_EXPIRES_IN=24h

# ── Blockchain (Ethereum / Hardhat local) ───────────────────────────────────
# RPC endpoint — use http://127.0.0.1:8545 for local Hardhat node
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Private key of the authorized backend wallet (Hardhat account #0 for dev)
# NEVER expose real private keys!
BACKEND_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Deployed FireAlertLogger contract address (set after deployment)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Email Notifications (Nodemailer) ────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=PyroChain Alerts <alerts@pyrochain.io>
FIRE_DEPT_EMAIL=firedept@example.com

# ── Alert Thresholds ─────────────────────────────────────────────────────────
SMOKE_THRESHOLD_LOW=300
SMOKE_THRESHOLD_MEDIUM=450
SMOKE_THRESHOLD_HIGH=600
TEMP_THRESHOLD_LOW=45
TEMP_THRESHOLD_MEDIUM=55
TEMP_THRESHOLD_HIGH=60
TEMP_THRESHOLD_CRITICAL=70

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Frontend URL (CORS) ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
